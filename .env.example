# ===== 환경 변수 예시 =====
# 로컬 개발: 이 파일을 .env.local 로 복사한 뒤 값을 채워 사용하세요.
# Vercel 배포: 아래 변수들을 Vercel 대시보드의 Project Settings → Environment Variables 에 등록하세요.

# 세션 쿠키 서명에 쓰이는 비밀 키. 충분히 길고 랜덤한 값이어야 합니다.
# 생성 방법: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# 계정 목록: JSON 을 base64 로 인코딩한 값.
#   원본 JSON 예시: [{"username":"admin","passwordHash":"$2a$10$..."}]
#   ('$' 문자가 .env 파서의 변수 확장과 충돌하기 때문에 base64 로 감쌉니다)
# 생성 방법:
#   1) 비밀번호 해시 생성:  npm run hash-password -- <비밀번호>
#   2) 위 형식의 JSON 을 직접 만들어서 다음 명령으로 base64 인코딩:
#      node -e "console.log(Buffer.from(JSON.stringify([{username:'admin',passwordHash:'<HASH>'}])).toString('base64'))"
#   - 더 간단하게는: npm run build-auth-users -- admin:<비밀번호> test:<비밀번호>
AUTH_USERS_B64=

# (선택) 상단 네비게이션의 Notion 버튼이 가리킬 URL. 비워두면 비활성 상태로 표시됩니다.
NEXT_PUBLIC_NOTION_URL=

# admin 권한을 가진 사용자 이름 목록 (콤마 구분). 여기에 포함된 username 만 admin UI 에 접근 가능.
ADMIN_USERNAMES=admin

# Neon Postgres 연결 문자열.
#   로컬: https://neon.tech 에서 무료 프로젝트 생성 후 connection string 복사
#   Vercel: Storage → Create Database (Neon) 를 누르면 자동 주입됨
DATABASE_URL=
